<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
<title>AI Deep Dive | Observe with Satyam</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root{
  --teal:#00d4c8;--teal-dim:#00a89e;--gold:#ffd166;--gold-dim:#f5a623;
  --slate:#0f172a;--slate-mid:#1e293b;--slate-light:#334155;
  --text:#e2e8f0;--text-dim:#94a3b8;
  --card-bg:rgba(30,41,59,0.85);--border:rgba(0,212,200,0.18);
  --danger:#ef4444;--success:#10b981;--purple:#a855f7;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Space Grotesk',sans-serif;background:var(--slate);color:var(--text);min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;z-index:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;}

/* ─── HEADER ─── */
header{position:sticky;top:0;z-index:200;background:rgba(15,23,42,0.96);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);}
.hdr{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:62px;padding:0 1.2rem;gap:1rem;}
.brand{display:flex;align-items:center;gap:9px;text-decoration:none;}
.brand-icon{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--teal),var(--teal-dim));display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:.95rem;color:var(--slate);box-shadow:0 0 14px rgba(0,212,200,.45);}
.brand-name{font-family:'Syne',sans-serif;font-size:1.05rem;font-weight:800;color:#ffffff;text-shadow:0 0 20px rgba(0,212,200,.3);}
.brand-name span{background:linear-gradient(135deg,var(--teal),#7fffd4);-webkit-background-clip:text;background-clip:text;color:transparent;}
.hdr-right{display:flex;align-items:center;gap:.9rem;}
.socials{display:flex;gap:.9rem;}
.socials a{color:var(--text-dim);font-size:.95rem;transition:color .2s,transform .2s;}
.socials a:hover{color:var(--teal);transform:translateY(-1px);}

/* YouTube Subscribe Button */
.yt-btn{display:flex;align-items:center;gap:.4rem;background:#FF0000;color:#fff;border:none;padding:.42rem .9rem;border-radius:999px;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:.78rem;cursor:pointer;text-decoration:none;white-space:nowrap;box-shadow:0 0 14px rgba(255,0,0,.4);position:relative;overflow:hidden;transition:background .2s,transform .15s;}
.yt-btn:hover{background:#cc0000;transform:scale(1.04);}
.yt-btn i{font-size:.85rem;}
@keyframes ytPulse{0%,100%{box-shadow:0 0 10px rgba(255,0,0,.4);}50%{box-shadow:0 0 22px rgba(255,0,0,.75),0 0 36px rgba(255,0,0,.3);}}
.yt-btn{animation:ytPulse 2.2s ease-in-out infinite;}

/* ─── TABS ─── */
.tab-nav{max-width:1200px;margin:0 auto;padding:1rem 1rem 0;display:flex;gap:.4rem;flex-wrap:wrap;position:relative;z-index:1;}
.tab-btn{padding:.5rem 1.1rem;border-radius:999px;border:1px solid var(--border);background:transparent;color:var(--text-dim);font-family:'Space Grotesk',sans-serif;font-size:.82rem;font-weight:600;cursor:pointer;transition:all .25s;display:flex;align-items:center;gap:.35rem;}
.tab-btn.active{background:var(--teal);color:var(--slate);border-color:var(--teal);box-shadow:0 0 16px rgba(0,212,200,.32);}
.tab-btn:not(.active):hover{border-color:var(--teal);color:var(--teal);}
.tab-content{display:none;position:relative;z-index:1;}
.tab-content.active{display:block;}
.container{max-width:1060px;margin:0 auto;padding:1.5rem 1rem 4rem;}

/* ─── HERO ─── */
.hero{text-align:center;padding:2.5rem 0 1.8rem;}
.eyebrow{display:inline-flex;align-items:center;gap:.4rem;background:rgba(0,212,200,.08);border:1px solid var(--border);color:var(--teal);font-size:.75rem;font-weight:600;padding:.35rem .9rem;border-radius:999px;margin-bottom:1rem;letter-spacing:.06em;text-transform:uppercase;}
.hero h1{font-family:'Syne',sans-serif;font-size:clamp(2rem,5vw,3.2rem);font-weight:800;line-height:1.1;background:linear-gradient(135deg,#fff 30%,var(--teal));-webkit-background-clip:text;background-clip:text;color:transparent;margin-bottom:.9rem;}
.hero p{color:var(--text-dim);font-size:.98rem;max-width:560px;margin:0 auto;line-height:1.7;}

/* ─── CARDS ─── */
.card{background:var(--card-bg);border:1px solid var(--border);border-radius:18px;overflow:hidden;margin-bottom:1.3rem;backdrop-filter:blur(12px);transition:border-color .3s;}
.card:hover{border-color:rgba(0,212,200,.32);}
.card-hd{display:flex;align-items:center;gap:.9rem;padding:1rem 1.4rem;background:rgba(0,0,0,.2);border-bottom:1px solid var(--border);flex-wrap:wrap;}
.step-badge{width:30px;height:30px;border-radius:9px;background:linear-gradient(135deg,var(--teal),var(--teal-dim));color:var(--slate);font-weight:800;font-size:.8rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.card-hd h2{font-family:'Syne',sans-serif;font-size:1.05rem;font-weight:700;}
.card-bd{padding:1.3rem 1.4rem;}
@media(max-width:600px){.card-bd{padding:1rem;}}

/* ─── ATTENTION COMPONENTS ─── */
.tokens-row{display:flex;flex-wrap:wrap;gap:.55rem;justify-content:center;padding:.8rem 0;}
.token{padding:.45rem 1rem;border-radius:999px;background:rgba(0,212,200,.07);border:1.5px solid rgba(0,212,200,.22);font-family:'JetBrains Mono',monospace;font-size:.85rem;font-weight:500;cursor:pointer;transition:all .2s;}
.token:hover{border-color:var(--teal);background:rgba(0,212,200,.15);transform:translateY(-2px);}
.token.selected{background:var(--teal);color:var(--slate);border-color:var(--teal);box-shadow:0 0 14px rgba(0,212,200,.4);transform:translateY(-2px);}
.qkv-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;}
@media(max-width:640px){.qkv-grid{grid-template-columns:1fr;}}
.qkv-card{background:rgba(0,0,0,.25);border-radius:12px;border:1px solid var(--border);padding:1rem;}
.bar-list{display:flex;flex-direction:column;gap:.55rem;}
.bar-row{display:flex;align-items:center;gap:.7rem;}
.bar-label{font-family:'JetBrains Mono',monospace;font-size:.78rem;width:68px;flex-shrink:0;color:var(--text-dim);}
.bar-track{flex:1;height:20px;background:rgba(255,255,255,.06);border-radius:999px;overflow:hidden;}
.bar-fill{height:100%;border-radius:999px;background:linear-gradient(90deg,var(--teal-dim),var(--teal));transition:width .6s cubic-bezier(.34,1.56,.64,1);}
.bar-fill.gold{background:linear-gradient(90deg,#d97706,var(--gold));}
.bar-val{font-family:'JetBrains Mono',monospace;font-size:.75rem;width:42px;text-align:right;color:var(--text-dim);flex-shrink:0;}
.heatmap-wrap{overflow-x:auto;padding-bottom:.5rem;}
.heatmap-grid{display:grid;gap:3px;min-width:480px;}
.hm-cell{height:38px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:.7rem;cursor:pointer;transition:all .15s;border:1px solid transparent;}
.hm-cell:hover{transform:scale(1.08);border-color:var(--teal);z-index:2;position:relative;}
.hm-cell.row-highlight{border-color:var(--teal);box-shadow:0 0 6px rgba(0,212,200,.3);}
.flow-vis{position:relative;padding:1.2rem 0;min-height:160px;}
.flow-tokens-row{display:flex;justify-content:space-around;position:relative;z-index:2;min-width:380px;overflow-x:auto;}
.flow-tok-box{padding:.4rem .7rem;border-radius:9px;font-family:'JetBrains Mono',monospace;font-size:.78rem;border:1.5px solid rgba(255,255,255,.12);background:rgba(255,255,255,.06);}
.flow-tok-box.src{border-color:var(--teal);background:rgba(0,212,200,.14);color:var(--teal);}
#flow-svg{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:1;}
.explain-box{background:rgba(0,212,200,.06);border:1px solid rgba(0,212,200,.2);border-left:4px solid var(--teal);border-radius:0 12px 12px 0;padding:.9rem 1.1rem;font-size:.88rem;line-height:1.7;color:var(--text-dim);}
.explain-box strong{color:var(--text);}
.formula-box{background:var(--slate-mid);border:1px solid var(--border);border-radius:14px;padding:1rem;text-align:center;margin:1rem 0;font-family:'JetBrains Mono',monospace;word-break:break-all;color:var(--teal);font-size:.95rem;}
.llm-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:.7rem;}
.llm-card{background:rgba(0,0,0,.2);border:1px solid var(--border);border-radius:11px;padding:.9rem;text-align:center;font-size:.85rem;}
.llm-card-icon{font-size:1.4rem;margin-bottom:.4rem;}

/* ─── STEP 10 ─── */
.sim10-controls{display:flex;align-items:center;gap:.65rem;flex-wrap:wrap;margin-bottom:1rem;}
.ctrl-btn{width:38px;height:38px;border-radius:50%;border:1px solid var(--border);background:transparent;color:var(--text);cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;font-size:.85rem;}
.ctrl-btn.primary{background:var(--teal);color:var(--slate);border-color:var(--teal);box-shadow:0 0 12px rgba(0,212,200,.35);}
.ctrl-btn:hover{border-color:var(--teal);color:var(--teal);}
.ctrl-btn.primary:hover{background:var(--teal-dim);}
.s10-phases{display:flex;gap:.4rem;overflow-x:auto;padding:.4rem 0 .8rem;scrollbar-width:none;-webkit-overflow-scrolling:touch;}
.s10-phases::-webkit-scrollbar{display:none;}
.s10-ph{padding:.4rem .9rem;border-radius:999px;font-size:.8rem;font-weight:600;cursor:pointer;transition:all .25s;white-space:nowrap;border:1px solid rgba(255,255,255,.1);color:var(--text-dim);}
.s10-ph.done{border-color:rgba(0,212,200,.4);color:var(--teal);}
.s10-ph.active{background:var(--teal);color:var(--slate);border-color:var(--teal);box-shadow:0 0 10px rgba(0,212,200,.3);}
.s10-canvas{background:rgba(0,0,0,.28);border-radius:14px;padding:1.5rem 1.2rem;min-height:240px;overflow-x:auto;}
.s10-explain{display:flex;align-items:flex-start;gap:.8rem;margin-top:1.2rem;padding:1rem 1.1rem;background:rgba(0,212,200,.07);border-radius:12px;border-left:4px solid var(--teal);}
.s10-explain-icon{font-size:1.4rem;flex-shrink:0;}
.s10-explain-text{font-size:.87rem;line-height:1.7;color:var(--text-dim);}
.s10-explain-text strong{color:var(--text);}
.focus-chip{background:rgba(0,212,200,.1);padding:.3rem .7rem;border-radius:6px;font-size:.78rem;border:1px solid var(--border);color:var(--teal);}
.v-box{border-radius:11px;border:1.5px solid rgba(255,255,255,.1);background:rgba(15,23,42,.95);padding:.6rem .8rem;text-align:center;transition:all .3s;}
.v-box.lit{border-color:var(--teal);box-shadow:0 0 0 2px rgba(0,212,200,.15),0 4px 16px rgba(0,212,200,.2);}
.v-box.gold-lit{border-color:var(--gold);box-shadow:0 0 0 2px rgba(255,209,102,.15);}
.v-box.pur-lit{border-color:var(--purple);box-shadow:0 0 0 2px rgba(168,85,247,.15);}
.v-box.grn-lit{border-color:#34d399;box-shadow:0 0 0 2px rgba(52,211,153,.15);}
.v-lbl{font-size:.6rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;margin-bottom:.2rem;}
.v-val{font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--text-dim);line-height:1.4;}
.v-val.bright{color:var(--text);}
.wsum-row{display:flex;align-items:center;gap:.6rem;margin-bottom:5px;}
.wsum-tok{font-size:.72rem;width:60px;flex-shrink:0;color:var(--text-dim);}
.wsum-track{flex:1;height:16px;background:rgba(255,255,255,.06);border-radius:999px;overflow:hidden;}
.wsum-fill{height:100%;border-radius:999px;background:linear-gradient(90deg,var(--teal-dim),var(--teal));transition:width .5s cubic-bezier(.34,1.56,.64,1);}
.wsum-fill.gold{background:linear-gradient(90deg,#d97706,var(--gold));}
.wsum-val{font-family:'JetBrains Mono',monospace;font-size:.7rem;width:36px;text-align:right;color:var(--text-dim);flex-shrink:0;}
@keyframes outPop{from{transform:scale(.85);opacity:0;}60%{transform:scale(1.05);}to{transform:scale(1);opacity:1;}}
.out-pop{animation:outPop .45s ease forwards;}
.s10-hm{display:grid;gap:2px;}
.s10-hm-cell{height:26px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:.62rem;transition:all .3s;}
.s10-hm-cell.row-active{outline:1.5px solid var(--teal);}

/* ─── SAFETY ─── */
.timeline{position:relative;padding:1.5rem 0;}
.timeline::before{content:'';position:absolute;top:0;bottom:0;left:22px;width:2px;background:linear-gradient(to bottom,var(--danger),var(--gold),var(--success));opacity:.5;}
@media(min-width:768px){.timeline::before{left:50%;transform:translateX(-50%);}}
.tl-item{position:relative;margin-bottom:1.8rem;padding-left:54px;}
@media(min-width:768px){.tl-item{display:flex;padding-left:0;justify-content:center;}
.tl-item:nth-child(odd){flex-direction:row-reverse;}
.tl-item:nth-child(odd) .tl-box{text-align:right;}}
.tl-dot{position:absolute;left:10px;top:0;width:26px;height:26px;border-radius:50%;background:var(--slate);border:3px solid var(--teal);display:flex;align-items:center;justify-content:center;z-index:2;transition:all .3s;font-size:.7rem;}
@media(min-width:768px){.tl-dot{left:50%;transform:translateX(-50%);}}
.tl-item:hover .tl-dot{background:var(--teal);box-shadow:0 0 12px rgba(0,212,200,.5);}
.tl-box{background:var(--card-bg);border:1px solid var(--border);border-radius:14px;padding:1.1rem;max-width:440px;width:100%;cursor:pointer;transition:all .3s;}
.tl-box:hover{border-color:var(--gold);transform:translateY(-2px);}
@media(min-width:768px){.tl-box{margin:0 38px;}}
.tl-step{font-size:.72rem;color:var(--gold);text-transform:uppercase;letter-spacing:1px;margin-bottom:.25rem;font-weight:600;}
.tl-title{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;display:flex;align-items:center;justify-content:space-between;margin-bottom:.4rem;}
.tl-desc{font-size:.85rem;color:var(--text-dim);line-height:1.5;}
.tl-detail{display:none;margin-top:.9rem;padding-top:.9rem;border-top:1px solid rgba(255,255,255,.08);}
.tl-box.open .tl-detail{display:block;animation:fadeIn .3s ease;}
.tl-box.open .chev{transform:rotate(180deg);}
.chev{transition:transform .3s;color:var(--text-dim);}
.risk-box{font-size:.84rem;padding:.75rem;border-radius:9px;margin-bottom:.6rem;line-height:1.5;}
.risk-in{background:rgba(239,68,68,.1);border-left:3px solid var(--danger);}
.risk-out{background:rgba(16,185,129,.1);border-left:3px solid var(--success);}
.risk-title{font-weight:600;margin-bottom:.25rem;display:flex;align-items:center;gap:.35rem;}
.risk-in .risk-title{color:#fca5a5;}
.risk-out .risk-title{color:#6ee7b7;}
.risk-tag{background:rgba(239,68,68,.1);border:1px solid var(--danger);padding:.35rem .8rem;border-radius:8px;font-size:.82rem;color:#fca5a5;cursor:pointer;transition:all .2s;display:inline-block;margin:.3rem .25rem;}
.risk-tag:hover{background:rgba(239,68,68,.22);transform:translateY(-1px);}
@keyframes fadeIn{from{opacity:0;transform:translateY(-4px);}to{opacity:1;transform:translateY(0);}}

/* ─── SAFETY INFOGRAPHIC ─── */
.safety-infographic{background:linear-gradient(135deg,rgba(15,23,42,.98),rgba(10,15,30,.98));border:1px solid var(--border);border-radius:22px;padding:2rem 1.5rem;margin:2rem 0;overflow:hidden;position:relative;}
.safety-infographic::before{content:'';position:absolute;top:-60px;right:-60px;width:200px;height:200px;background:radial-gradient(circle,rgba(0,212,200,.08),transparent 70%);pointer-events:none;}
.si-title{font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:800;color:#fff;margin-bottom:.4rem;display:flex;align-items:center;gap:.6rem;}
.si-subtitle{font-size:.85rem;color:var(--text-dim);margin-bottom:1.8rem;line-height:1.5;}
.si-layers{display:flex;flex-direction:column;gap:0;}
.si-layer{display:flex;align-items:center;gap:1rem;padding:.7rem 1rem;border-radius:10px;margin-bottom:4px;transition:all .25s;cursor:pointer;position:relative;overflow:hidden;}
.si-layer:hover{transform:translateX(6px);}
.si-layer-num{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-weight:700;font-size:.75rem;flex-shrink:0;color:#fff;}
.si-layer-content{flex:1;}
.si-layer-title{font-weight:700;font-size:.85rem;color:#fff;}
.si-layer-tag{font-size:.7rem;color:var(--text-dim);margin-top:.1rem;}
.si-layer-icon{font-size:1.1rem;flex-shrink:0;}
.si-layer-bar{position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:4px;}
.si-stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:.8rem;margin-top:1.8rem;}
.si-stat{background:rgba(0,0,0,.3);border:1px solid var(--border);border-radius:12px;padding:.9rem;text-align:center;}
.si-stat-num{font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:800;background:linear-gradient(135deg,var(--teal),#7fffd4);-webkit-background-clip:text;background-clip:text;color:transparent;}
.si-stat-label{font-size:.72rem;color:var(--text-dim);margin-top:.2rem;}

/* ─── MIND MAP ─── */
.mm-outer{max-width:1200px;margin:0 auto;padding:2rem 1rem 3rem;}
.mm-hero{text-align:center;margin-bottom:2rem;}
.mm-hero h1{font-family:'Syne',sans-serif;font-size:clamp(2rem,5vw,3rem);background:linear-gradient(135deg,#fff 30%,var(--gold));-webkit-background-clip:text;background-clip:text;color:transparent;margin:.7rem 0;}
.mm-wrap{position:relative;width:100%;min-height:680px;}
#mmCanvas{position:relative;width:100%;min-height:680px;}
.mm-hub{position:absolute;z-index:10;width:190px;height:190px;top:50%;left:50%;transform:translate(-50%,-50%);background:radial-gradient(circle at 35% 35%,#ffe066,#f5a623);border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;box-shadow:0 0 0 8px rgba(245,166,35,.14),0 18px 36px rgba(0,0,0,.5);border:2px solid rgba(255,255,255,.25);}
.mm-hub-title{font-family:'Syne',sans-serif;font-size:.95rem;font-weight:800;color:#1a0f00;line-height:1.2;margin-top:.4rem;}
.mm-hub-sub{font-size:.6rem;font-weight:700;background:rgba(255,255,255,.4);color:#2a1500;padding:2px 9px;border-radius:999px;margin-top:.3rem;}
.mm-node{position:absolute;z-index:5;width:210px;background:rgba(12,22,48,.92);backdrop-filter:blur(14px);border:1.5px solid rgba(245,166,35,.35);border-radius:20px;padding:.9rem .8rem;cursor:pointer;transition:all .25s cubic-bezier(.34,1.56,.64,1);text-align:center;box-shadow:0 7px 22px rgba(0,0,0,.4);}
.mm-node:hover{transform:scale(1.06) !important;border-color:var(--gold);background:rgba(18,32,70,.98);z-index:20;box-shadow:0 10px 28px rgba(0,0,0,.5),0 0 0 2px rgba(245,166,35,.55);}
.mm-node-name{font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:800;background:linear-gradient(135deg,var(--gold),#f5a623);-webkit-background-clip:text;background-clip:text;color:transparent;margin-bottom:.3rem;}
.mm-node-form{font-size:.66rem;color:#a8b8d8;line-height:1.4;background:rgba(0,0,0,.3);border-radius:7px;padding:3px 7px;display:inline-block;margin-bottom:.4rem;}
.mm-node-meaning{font-size:.7rem;color:var(--text-dim);line-height:1.4;margin-bottom:.4rem;}
.mm-node-cta{font-size:.68rem;color:rgba(245,166,35,.8);display:flex;align-items:center;justify-content:center;gap:.3rem;}
@media(max-width:820px){
  #mmCanvas{display:flex;flex-direction:column;align-items:center;gap:1rem;min-height:auto !important;height:auto !important;padding:1rem 0 2rem;}
  .mm-hub{position:relative !important;left:auto !important;top:auto !important;transform:none !important;margin-bottom:1rem;width:140px;height:140px;}
  .mm-hub-title{font-size:.8rem;}
  .mm-node{position:relative !important;left:auto !important;top:auto !important;width:100% !important;max-width:400px;transform:none !important;}
  .mm-node:hover{transform:translateY(-2px) !important;}
  #mmSvg{display:none !important;}
}

/* ─── MODAL ─── */
