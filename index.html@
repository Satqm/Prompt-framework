let loopStep=0,loopTimer=null;
function runLoopDemo(){
  if(loopTimer)clearInterval(loopTimer);loopStep=0;
  const nodes=document.querySelectorAll('#agent-loop .loop-node');
  nodes.forEach(n=>n.classList.remove('active-step'));
  loopTimer=setInterval(()=>{nodes.forEach(n=>n.classList.remove('active-step'));nodes[loopStep%4].classList.add('active-step');loopStep++;},900);
  setTimeout(()=>{clearInterval(loopTimer);nodes.forEach(n=>n.classList.remove('active-step'));},4500);
}
