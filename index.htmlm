<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Deep Dive | Observe with Satyam</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --teal: #00d4c8;
      --teal-dim: #00a89e;
      --gold: #ffd166;
      --gold-dim: #f5a623;
      --slate: #0f172a;
      --slate-mid: #1e293b;
      --slate-light: #334155;
      --text: #e2e8f0;
      --text-dim: #94a3b8;
      --card-bg: rgba(30, 41, 59, 0.8);
      --border: rgba(0, 212, 200, 0.18);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Space Grotesk', sans-serif;
      background: var(--slate);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ───── NOISE OVERLAY ───── */
    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
    }

    /* ───── HEADER ───── */
    header {
      position: sticky; top: 0; z-index: 100;
      background: rgba(15, 23, 42, 0.85);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
    }
    .header-inner {
      max-width: 1200px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
      height: 64px; gap: 1rem;
    }
    .brand {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none;
    }
    .brand-icon {
      width: 36px; height: 36px; border-radius: 10px;
      background: linear-gradient(135deg, var(--teal), var(--teal-dim));
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem; color: var(--slate); font-weight: 800;
      box-shadow: 0 0 12px rgba(0,212,200,0.3);
    }
    .brand-name {
      font-family: 'Syne', sans-serif;
      font-size: 1.1rem; font-weight: 800;
      color: var(--text);
    }
    .brand-name span { color: var(--teal); }
    .socials { display: flex; gap: 1rem; }
    .socials a {
      color: var(--text-dim); font-size: 1rem;
      transition: color 0.2s, transform 0.2s;
    }
    .socials a:hover { color: var(--teal); transform: translateY(-1px); }

    /* ───── TAB NAV ───── */
    .tab-nav {
      max-width: 1200px; margin: 0 auto;
      padding: 1.5rem 2rem 0;
      display: flex; gap: 0.5rem;
      position: relative; z-index: 1;
    }
    .tab-btn {
      padding: 0.6rem 1.4rem; border-radius: 999px;
      border: 1px solid var(--border);
      background: transparent; color: var(--text-dim);
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.9rem; font-weight: 600;
      cursor: pointer; transition: all 0.25s;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .tab-btn.active {
      background: var(--teal); color: var(--slate);
      border-color: var(--teal);
      box-shadow: 0 0 18px rgba(0,212,200,0.35);
    }
    .tab-btn:not(.active):hover {
      border-color: var(--teal); color: var(--teal);
    }

    /* ───── MAIN CONTENT WRAP ───── */
    .tab-content { display: none; position: relative; z-index: 1; }
    .tab-content.active { display: block; }
    .container { max-width: 1100px; margin: 0 auto; padding: 2rem 2rem 4rem; }

    /* ───── HERO ───── */
    .hero {
      text-align: center; padding: 3rem 0 2rem;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: rgba(0,212,200,0.1); border: 1px solid var(--border);
      color: var(--teal); font-size: 0.8rem; font-weight: 600;
      padding: 0.4rem 1rem; border-radius: 999px; margin-bottom: 1.2rem;
      letter-spacing: 0.05em; text-transform: uppercase;
    }
    .hero h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2.2rem, 5vw, 3.5rem);
      font-weight: 800; line-height: 1.1;
      background: linear-gradient(135deg, #fff 30%, var(--teal));
      -webkit-background-clip: text; background-clip: text; color: transparent;
      margin-bottom: 1rem;
    }
    .hero p {
      color: var(--text-dim); font-size: 1.1rem;
      max-width: 600px; margin: 0 auto; line-height: 1.7;
    }

    /* ───── SECTION CARDS ───── */
    .section-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 20px;
      overflow: hidden;
      margin-bottom: 1.5rem;
      backdrop-filter: blur(12px);
      transition: border-color 0.3s;
    }
    .section-card:hover { border-color: rgba(0,212,200,0.35); }
    .card-header {
      display: flex; align-items: center; gap: 1rem;
      padding: 1.2rem 1.5rem;
      background: rgba(0,0,0,0.2);
      border-bottom: 1px solid var(--border);
    }
    .step-badge {
      width: 32px; height: 32px; border-radius: 10px;
      background: linear-gradient(135deg, var(--teal), var(--teal-dim));
      color: var(--slate); font-weight: 800; font-size: 0.85rem;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .card-header h2 {
      font-family: 'Syne', sans-serif;
      font-size: 1.15rem; font-weight: 700;
    }
    .card-body { padding: 1.5rem; }

    /* ───── TOKEN DISPLAY ───── */
    .tokens-row {
      display: flex; flex-wrap: wrap; gap: 0.6rem;
      justify-content: center; padding: 1rem;
    }
    .token {
      padding: 0.5rem 1.1rem; border-radius: 999px;
      background: rgba(0,212,200,0.08);
      border: 1.5px solid rgba(0,212,200,0.25);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.9rem; font-weight: 500;
      cursor: pointer; transition: all 0.2s;
      position: relative;
    }
    .token:hover { border-color: var(--teal); background: rgba(0,212,200,0.15); transform: translateY(-2px); }
    .token.selected {
      background: var(--teal); color: var(--slate);
      border-color: var(--teal);
      box-shadow: 0 0 16px rgba(0,212,200,0.4);
      transform: translateY(-2px);
    }
    .token-idx {
      position: absolute; top: -6px; right: -4px;
      width: 16px; height: 16px; border-radius: 50%;
      background: var(--slate-mid); border: 1px solid var(--border);
      font-size: 0.55rem; display: flex; align-items: center; justify-content: center;
      color: var(--text-dim);
    }

    /* ───── QKV TABLE ───── */
    .qkv-grid {
      display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;
    }
    @media(max-width:640px) { .qkv-grid { grid-template-columns: 1fr; } }
    .qkv-card {
      background: rgba(0,0,0,0.25); border-radius: 14px;
      border: 1px solid var(--border); padding: 1rem;
    }
    .qkv-label {
      font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700;
      margin-bottom: 0.4rem;
    }
    .qkv-label.q { color: #a78bfa; }
    .qkv-label.k { color: #f59e0b; }
    .qkv-label.v { color: #34d399; }
    .qkv-role {
      font-size: 0.75rem; color: var(--text-dim); margin-bottom: 0.7rem;
      line-height: 1.4;
    }
    .qkv-vec {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem; color: var(--text);
      background: rgba(0,0,0,0.3); border-radius: 8px;
      padding: 0.5rem 0.6rem; line-height: 1.8;
    }

    /* ───── BAR CHART ───── */
    .bar-list { display: flex; flex-direction: column; gap: 0.6rem; }
    .bar-row { display: flex; align-items: center; gap: 0.75rem; }
    .bar-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem; width: 70px; flex-shrink: 0; color: var(--text-dim);
    }
    .bar-track {
      flex: 1; height: 22px; background: rgba(255,255,255,0.06);
      border-radius: 999px; overflow: hidden;
    }
    .bar-fill {
      height: 100%; border-radius: 999px;
      background: linear-gradient(90deg, var(--teal-dim), var(--teal));
      transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
      display: flex; align-items: center; justify-content: flex-end;
      padding-right: 6px;
    }
    .bar-fill.gold { background: linear-gradient(90deg, #d97706, var(--gold)); }
    .bar-val {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem; width: 48px; text-align: right;
      color: var(--text-dim); flex-shrink: 0;
    }

    /* ───── HEATMAP ───── */
    .heatmap-wrap { overflow-x: auto; }
    .heatmap-grid {
      display: grid; gap: 4px;
      min-width: 500px;
    }
    .hm-cell {
      height: 40px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-family: 'JetBrains Mono', monospace; font-size: 0.72rem;
      cursor: pointer; transition: all 0.15s;
      border: 1px solid transparent;
    }
    .hm-cell:hover { transform: scale(1.08); border-color: var(--teal); z-index: 2; position: relative; }
    .hm-header {
      height: 40px; display: flex; align-items: center; justify-content: center;
      font-size: 0.78rem; font-weight: 600; color: var(--teal);
    }
    .hm-row-label {
      height: 40px; display: flex; align-items: center;
      font-size: 0.78rem; font-weight: 600; color: var(--text-dim);
    }
    .hm-cell.row-highlight { border-color: var(--teal); box-shadow: 0 0 8px rgba(0,212,200,0.3); }

    /* ───── ATTENTION SVG FLOW ───── */
    .flow-vis { position: relative; padding: 1.5rem; }
    .flow-tokens-row {
      display: flex; justify-content: space-around; position: relative; z-index: 2;
    }
    .flow-token {
      display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
    }
    .flow-token-box {
      padding: 0.4rem 0.8rem; border-radius: 10px;
      font-family: 'JetBrains Mono', monospace; font-size: 0.8rem;
      border: 1.5px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.06);
      transition: all 0.3s;
    }
    .flow-token-box.source { border-color: var(--teal); background: rgba(0,212,200,0.15); color: var(--teal); }
    .flow-attn-label {
      font-family: 'JetBrains Mono', monospace; font-size: 0.65rem;
      color: var(--text-dim);
    }
    #flow-svg {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none; z-index: 1;
    }

    /* ───── EXPLAIN BOX ───── */
    .explain-box {
      background: rgba(0,212,200,0.06);
      border: 1px solid rgba(0,212,200,0.2);
      border-left: 4px solid var(--teal);
      border-radius: 0 12px 12px 0;
      padding: 1rem 1.2rem;
      font-size: 0.9rem; line-height: 1.7;
      color: var(--text-dim);
    }
    .explain-box strong { color: var(--text); }

    /* ───── SIMULATOR PIPELINE ───── */
    .pipeline {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0.6rem; position: relative;
    }
    @media(max-width:700px) {
      .pipeline { grid-template-columns: 1fr 1fr; }
    }
    .pipe-stage {
      background: rgba(0,0,0,0.25); border: 1px solid var(--border);
      border-radius: 14px; padding: 1rem 0.8rem;
      transition: all 0.3s; text-align: center;
    }
    .pipe-stage.active {
      border-color: var(--teal);
      background: rgba(0,212,200,0.08);
      box-shadow: 0 0 20px rgba(0,212,200,0.2);
    }
    .pipe-stage-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem; color: var(--teal); margin-bottom: 0.3rem;
    }
    .pipe-stage-title {
      font-size: 0.8rem; font-weight: 600; margin-bottom: 0.6rem;
    }
    .pipe-stage-content { font-size: 0.72rem; color: var(--text-dim); line-height: 1.5; }

    /* ───── CONTROLS ───── */
    .sim-controls {
      display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;
    }
    .ctrl-btn {
      width: 40px; height: 40px; border-radius: 50%;
      border: 1px solid var(--border); background: transparent;
      color: var(--text); cursor: pointer; transition: all 0.2s;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.9rem;
    }
    .ctrl-btn:hover { border-color: var(--teal); color: var(--teal); }
    .ctrl-btn.primary {
      background: var(--teal); color: var(--slate); border-color: var(--teal);
      box-shadow: 0 0 14px rgba(0,212,200,0.35);
    }
    .ctrl-btn.primary:hover { background: var(--teal-dim); }
    .stage-dots { display: flex; gap: 0.4rem; align-items: center; }
    .stage-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--border); border: 1px solid var(--border);
      transition: all 0.3s; cursor: pointer;
    }
    .stage-dot.active { background: var(--teal); border-color: var(--teal); transform: scale(1.3); }
    .focus-chip {
      background: rgba(0,212,200,0.1); border: 1px solid var(--border);
      padding: 0.3rem 0.8rem; border-radius: 999px;
      font-size: 0.78rem; color: var(--teal);
      font-family: 'JetBrains Mono', monospace;
    }

    /* ───── FORMULA BOX ───── */
    .formula-box {
      background: var(--slate-mid); border: 1px solid var(--border);
      border-radius: 16px; padding: 1.5rem 2rem;
      text-align: center; margin: 1.5rem 0;
    }
    .formula {
      font-family: 'JetBrains Mono', monospace;
      font-size: clamp(0.85rem, 2.5vw, 1.1rem);
      color: var(--teal); letter-spacing: 0.02em;
    }
    .formula-label { font-size: 0.8rem; color: var(--text-dim); margin-top: 0.5rem; }

    /* ───── LLMS SECTION ───── */
    .llm-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 0.8rem; margin-top: 1rem;
    }
    .llm-card {
      background: rgba(0,0,0,0.25); border: 1px solid var(--border);
      border-radius: 12px; padding: 1rem; text-align: center;
    }
    .llm-card-icon { font-size: 1.5rem; margin-bottom: 0.5rem; }
    .llm-card-title { font-weight: 600; font-size: 0.9rem; margin-bottom: 0.3rem; }
    .llm-card-desc { font-size: 0.78rem; color: var(--text-dim); line-height: 1.5; }

    /* ═══════════════════════════════════════════
       TAB 2: MIND MAP
    ═══════════════════════════════════════════ */
    #tab-mindmap {
      background: radial-gradient(ellipse at 20% 20%, #0d1f3c 0%, #050d1a 60%);
      min-height: calc(100vh - 64px);
    }
    .mindmap-outer {
      max-width: 1200px; margin: 0 auto; padding: 2rem;
    }
    .mindmap-hero { text-align: center; padding: 2rem 0 1.5rem; }
    .mindmap-hero h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 800;
      background: linear-gradient(135deg, #fff 30%, var(--gold));
      -webkit-background-clip: text; background-clip: text; color: transparent;
      margin-bottom: 0.75rem;
    }
    .mindmap-hero p { color: #94a3b8; font-size: 1rem; }
    .mindmap-canvas-wrap {
      position: relative;
      width: 100%; min-height: 650px;
      display: flex; align-items: center; justify-content: center;
    }
    #mmCanvas {
      position: relative; width: 100%; min-height: 650px;
    }
    #mmSvg {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none; z-index: 1;
    }

    /* Central hub */
    .mm-hub {
      position: absolute; z-index: 10;
      width: 200px; height: 200px;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      background: radial-gradient(circle at 35% 35%, #ffe066, #f5a623);
      border-radius: 50%;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center; text-align: center;
      box-shadow: 0 0 0 8px rgba(245,166,35,0.15), 0 20px 40px rgba(0,0,0,0.5);
      border: 2px solid rgba(255,255,255,0.25);
      cursor: default;
    }
    .mm-hub i { font-size: 2.5rem; color: #1a0f00; }
    .mm-hub-title {
      font-family: 'Syne', sans-serif;
      font-size: 1rem; font-weight: 800; color: #1a0f00;
      line-height: 1.2; margin-top: 0.5rem;
    }
    .mm-hub-sub {
      font-size: 0.65rem; font-weight: 700;
      background: rgba(255,255,255,0.4); color: #2a1500;
      padding: 2px 10px; border-radius: 999px; margin-top: 0.3rem;
    }

    /* Framework nodes */
    .mm-node {
      position: absolute; z-index: 5;
      width: 195px;
      background: rgba(15, 28, 55, 0.9);
      backdrop-filter: blur(16px);
      border: 1.5px solid rgba(245,166,35,0.4);
      border-radius: 22px;
      padding: 1rem 0.8rem;
      cursor: pointer;
      transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
      text-align: center;
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    }
    .mm-node:hover {
      transform: scale(1.07) !important;
      border-color: var(--gold);
      box-shadow: 0 12px 32px rgba(0,0,0,0.5), 0 0 0 2px rgba(245,166,35,0.6);
      background: rgba(25, 40, 75, 0.95);
    }
    .mm-node-name {
      font-family: 'Syne', sans-serif;
      font-size: 1.4rem; font-weight: 800;
      background: linear-gradient(135deg, var(--gold), #f5a623);
      -webkit-background-clip: text; background-clip: text; color: transparent;
      margin-bottom: 0.4rem;
    }
    .mm-node-form {
      font-size: 0.68rem; color: #a8b8d8; line-height: 1.4;
      background: rgba(0,0,0,0.3); border-radius: 8px;
      padding: 4px 8px; display: inline-block; margin-bottom: 0.5rem;
    }
    .mm-node-cta {
      font-size: 0.7rem; color: rgba(245,166,35,0.8);
      display: flex; align-items: center; justify-content: center; gap: 0.3rem;
    }

    /* ───── MODAL ───── */
    .modal-bg {
      position: fixed; inset: 0; z-index: 1000;
      background: rgba(5,13,26,0.8); backdrop-filter: blur(16px);
      display: flex; align-items: center; justify-content: center;
      padding: 1rem;
      opacity: 0; pointer-events: none; transition: opacity 0.2s;
    }
    .modal-bg.open { opacity: 1; pointer-events: all; }
    .modal {
      background: linear-gradient(145deg, #0f1e38, #080f1e);
      border: 1.5px solid rgba(245,166,35,0.5);
      border-radius: 28px; padding: 0;
      max-width: 560px; width: 100%;
      max-height: 90vh; overflow-y: auto;
      box-shadow: 0 40px 60px rgba(0,0,0,0.6);
      transform: scale(0.92); transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1);
    }
    .modal-bg.open .modal { transform: scale(1); }
    .modal-head {
      padding: 1.5rem 1.5rem 1rem;
      border-bottom: 1px solid rgba(245,166,35,0.2);
      display: flex; align-items: center; justify-content: space-between;
    }
    .modal-head h2 {
      font-family: 'Syne', sans-serif; font-size: 1.6rem; font-weight: 800;
      background: linear-gradient(120deg, var(--gold), #f5a623);
      -webkit-background-clip: text; background-clip: text; color: transparent;
    }
    .modal-close {
      width: 34px; height: 34px; border-radius: 50%;
      background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
      color: #aaa; cursor: pointer; display: flex; align-items: center; justify-content: center;
      font-size: 1rem; transition: all 0.2s;
    }
    .modal-close:hover { background: rgba(255,255,255,0.12); color: white; }
    .modal-body { padding: 1.2rem 1.5rem 1.5rem; }
    .modal-section { margin-bottom: 1.2rem; }
    .modal-section-label {
      font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--gold-dim);
      display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.4rem;
    }
    .modal-section p {
      font-size: 0.88rem; color: #ccd6f0; line-height: 1.65;
    }
    .modal-prompt-box {
      background: rgba(0,0,0,0.4); border: 1px solid rgba(245,166,35,0.3);
      border-left: 4px solid var(--gold-dim);
      border-radius: 0 12px 12px 0;
      padding: 0.9rem 1rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem; color: #e2d9c0; line-height: 1.65;
    }
    .modal-letters {
      display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.5rem;
    }
    .modal-letter-chip {
      background: rgba(245,166,35,0.1); border: 1px solid rgba(245,166,35,0.3);
      border-radius: 8px; padding: 0.4rem 0.7rem;
      font-size: 0.78rem;
    }
    .modal-letter-chip strong { color: var(--gold); }
    .modal-letter-chip span { color: #94a3b8; margin-left: 0.3rem; }

    /* ───── TOGGLE SWITCH ───── */
    .toggle-wrap { display: flex; align-items: center; gap: 0.5rem; font-size: 0.82rem; color: var(--text-dim); }
    .toggle { position: relative; width: 38px; height: 22px; }
    .toggle input { opacity: 0; width: 0; height: 0; }
    .toggle-slider {
      position: absolute; inset: 0; border-radius: 999px;
      background: var(--slate-light); cursor: pointer; transition: 0.25s;
    }
    .toggle-slider:before {
      content: ''; position: absolute;
      left: 2px; top: 2px; width: 18px; height: 18px;
      border-radius: 50%; background: white; transition: 0.25s;
    }
    .toggle input:checked + .toggle-slider { background: var(--teal); }
    .toggle input:checked + .toggle-slider:before { transform: translateX(16px); }

    /* ───── FOOTER ───── */
    footer {
      border-top: 1px solid var(--border); padding: 2rem;
      text-align: center; color: var(--text-dim); font-size: 0.82rem;
      position: relative; z-index: 1;
    }
    footer .socials { justify-content: center; margin-bottom: 0.75rem; }
    footer a { color: var(--text-dim); }
    footer a:hover { color: var(--teal); }

    /* ───── RESPONSIVE ───── */
    @media(max-width: 600px) {
      .tab-nav { padding: 1rem 1rem 0; }
      .container { padding: 1.2rem 1rem 3rem; }
      .mm-node { width: 155px; }
      .mm-hub { width: 150px; height: 150px; }
    }

    /* ───── PULSE ANIMATION ───── */
    @keyframes pulse-teal {
      0% { box-shadow: 0 0 0 0 rgba(0,212,200,0.4); }
      70% { box-shadow: 0 0 0 8px rgba(0,212,200,0); }
      100% { box-shadow: 0 0 0 0 rgba(0,212,200,0); }
    }
    .pulse { animation: pulse-teal 2s infinite; }

    /* Dash animation for SVG */
    @keyframes dash { to { stroke-dashoffset: -30; } }
    .animated-dash { animation: dash 1.5s linear infinite; }
  </style>
</head>
<body>

<!-- ═══════════ HEADER ═══════════ -->
<header>
  <div class="header-inner">
    <a class="brand" href="#">
      <div class="brand-icon">S</div>
      <span class="brand-name">Observe with <span>Satyam</span></span>
    </a>
    <div class="socials">
      <a href="https://www.instagram.com/" target="_blank"><i class="fab fa-instagram"></i></a>
      <a href="https://www.linkedin.com/in/satyam-kumar5286o" target="_blank"><i class="fab fa-linkedin-in"></i></a>
      <a href="https://youtube.com/@observe_with_satyam" target="_blank"><i class="fab fa-youtube"></i></a>
      <a href="https://t.me/CA_Protracker" target="_blank"><i class="fab fa-telegram-plane"></i></a>
    </div>
  </div>
</header>

<!-- ═══════════ TABS ═══════════ -->
<div class="tab-nav">
  <button class="tab-btn active" id="btn-attn" onclick="switchTab('attn')">
    <i class="fas fa-brain"></i> Attention Simulator
  </button>
  <button class="tab-btn" id="btn-mindmap" onclick="switchTab('mindmap')">
    <i class="fas fa-project-diagram"></i> Prompt Frameworks
  </button>
</div>

<!-- ══════════════════════════════════════════════
     TAB 1 — ATTENTION SIMULATOR
══════════════════════════════════════════════ -->
<div class="tab-content active" id="tab-attn">
  <div class="container">

    <!-- HERO -->
    <div class="hero">
      <div class="hero-eyebrow"><i class="fas fa-bolt"></i> Interactive Deep Dive</div>
      <h1>How Attention Works</h1>
      <p>Click a token. Watch it gather context from every other word — step by step, math made visible.</p>
    </div>

    <!-- STEP 1: Tokenization -->
    <div class="section-card">
      <div class="card-header">
        <div class="step-badge">1</div>
        <h2>Tokenization — Breaking the Sentence</h2>
      </div>
      <div class="card-body">
        <p style="color:var(--text-dim);font-size:0.9rem;margin-bottom:1rem;">Every sentence gets split into tokens. Click any token below to focus on it — all subsequent steps will show that token's perspective.</p>
        <div class="tokens-row" id="tokens-row"></div>
        <div class="explain-box" style="margin-top:1rem;">
          <strong>Real models</strong> use subword tokenizers (BPE) that split rare words. We're using word-level tokens for clarity. <strong>Click a token to begin.</strong>
        </div>
      </div>
    </div>

    <!-- STEP 2: Embeddings -->
    <div class="section-card">
      <div class="card-header">
        <div class="step-badge">2</div>
        <h2>Token Embeddings — Numbers that Carry Meaning</h2>
      </div>
      <div class="card-body">
        <p style="color:var(--text-dim);font-size:0.9rem;margin-bottom:1rem;">Each token is converted to a vector of numbers. Real models use 768–12288 dimensions. We use 4 for visibility.</p>
        <div id="embedding-display" style="font-family:'JetBrains Mono',monospace;font-size:0.85rem;background:rgba(0,0,0,0.25);border-radius:12px;padding:1rem;border:1px solid var(--border);"></div>
        <div class="explain-box" style="margin-top:1rem;">
          These embeddings are <strong>learned during training</strong> — the model adjusts these numbers so similar words end up close in vector space.
        </div>
      </div>
    </div>

    <!-- STEP 3: Why QKV -->
    <div class="section-card">
      <div class="card-header">
        <div class="step-badge">3</div>
        <h2>The Problem — Why Do We Need Q, K, V?</h2>
      </div>
      <div class="card-body">
        <p style="color:var(--text-dim);font-size:0.9rem;margin-bottom:1.2rem;">We need to make each word smarter by learning from context. Q, K, V split this into three distinct roles:</p>
        <div class="qkv-grid">
          <div class="qkv-card">
            <div class="qkv-label q">Q — Query</div>
            <div class="qkv-role">"What am I looking for?" — The focused question this token is asking of others.</div>
            <div style="font-size:0.75rem;color:#a78bfa;padding:4px 8px;background:rgba(167,139,250,0.1);border-radius:8px;">🔍 The seeker</div>
          </div>
          <div class="qkv-card">
            <div class="qkv-label k">K — Key</div>
            <div class="qkv-role">"What do I have to offer?" — Labels that describe what each token contains.</div>
            <div style="font-size:0.75rem;color:#f59e0b;padding:4px 8px;background:rgba(245,158,11,0.1);border-radius:8px;">🏷️ The descriptor</div>
          </div>
          <div class="qkv-card">
            <div class="qkv-label v">V — Value</div>
            <div class="qkv-role">"Here's my actual info." — The real content shared once a match is found.</div>
            <div style="font-size:0.75rem;color:#34d399;padding:4px 8px;background:rgba(52,211,153,0.1);border-radius:8px;">📦 The payload</div>
          </div>
        </div>
        <div class="explain-box" style="margin-top:1rem;">
          <strong>Key insight:</strong> Q and K find the match. V provides the content. The "magic" is entirely in the learned weight matrices W_Q, W_K, W_V.
        </div>
      </div>
    </div>

    <!-- STEP 4: Q K V Vectors -->
    <div class="section-card">
      <div class="card-header">
        <div class="step-badge">4</div>
        <h2>Computing Q, K, V — Matrix Multiplication</h2>
      </div>
      <div class="card-body">
        <p style="color:var(--text-dim);font-size:0.9rem;margin-bottom:1.2rem;">
          Focused on: <span id="qkv-focused" style="color:var(--teal);font-family:'JetBrains Mono',monospace;font-weight:600;"></span>
        </p>
        <div class="formula-box">
          <div class="formula">Q = W<sub>Q</sub> × E &nbsp;|&nbsp; K = W<sub>K</sub> × E &nbsp;|&nbsp; V = W<sub>V</sub> × E</div>
          <div class="formula-label">Same operation — different weight matrices. Weights are learned during training.</div>
        </div>
        <div class="qkv-grid" id="qkv-vectors"></div>
      </div>
    </div>

    <!-- STEP 5: Scores -->
    <div class="section-card">
      <div class="card-header">
        <div class="step-badge">5</div>
        <h2>Attention Scores — Q · K / √d</h2>
      </div>
      <div class="card-body">
        <p style="color:var(--text-dim);font-size:0.9rem;margin-bottom:1.2rem;">
          How similar is <span id="scores-focused" style="color:var(--teal);font-family:'JetBrains Mono',monospace;"></span>'s Query to every other token's Key? Higher dot product = stronger attention.
        </p>
        <div class="bar-list" id="scores-bars"></div>
        <div class="explain-box" style="margin-top:1rem;">
          We divide by <strong>√d = √4 = 2</strong> to prevent extremely large dot products that would make softmax too sharp (gradient vanishing).
        </div>
      </div>
    </div>

    <!-- STEP 6: Softmax -->
    <div class="section-card">
      <div class="card-header">
        <div class="step-badge">6</div>
        <h2>Softmax — Converting Scores to Probabilities</h2>
      </div>
      <div class="card-body">
        <p style="color:var(--text-dim);font-size:0.9rem;margin-bottom:1.2rem;">
          Raw scores become probabilities summing to 100%. This tells us: <em>how much should <span id="sm-focused" style="color:var(--teal);font-family:'JetBrains Mono',monospace;"></span> attend to each word?</em>
        </p>
        <div class="bar-list" id="softmax-bars"></div>
        <div class="formula-box" style="margin-top:1rem;">
          <div class="formula">softmax(xᵢ) = e^xᵢ / Σ e^xⱼ</div>
        </div>
      </div>
    </div>

    <!-- STEP 7: Attention Flow Visualization -->
    <div class="section-card">
      <div class="card-header">
        <div class="step-badge">7</div>
        <h2>Attention Flow — Visual Strength Map</h2>
      </div>
      <div class="card-body">
        <p style="color:var(--text-dim);font-size:0.9rem;margin-bottom:1rem;">
          Thicker lines = stronger attention. <span id="flow-focused" style="color:var(--teal);font-family:'JetBrains Mono',monospace;"></span> is radiating attention to all other tokens.
        </p>
        <div class="flow-vis" id="flow-vis" style="min-height:160px;">
          <svg id="flow-svg"></svg>
          <div class="flow-tokens-row" id="flow-tokens-row"></div>
        </div>
      </div>
    </div>

    <!-- STEP 8: Full Heatmap -->
    <div class="section-card">
      <div class="card-header">
        <div class="step-badge">8</div>
        <h2>Full Attention Matrix — Every Token to Every Token</h2>
      </div>
      <div class="card-body">
        <p style="color:var(--text-dim);font-size:0.9rem;margin-bottom:1rem;">
          Hover to highlight. Click any cell to focus on that token.
        </p>
        <div class="heatmap-wrap">
          <div id="heatmap" class="heatmap-grid"></div>
        </div>
      </div>
    </div>

    <!-- STEP 9: Output -->
    <div class="section-card">
      <div class="card-header">
        <div class="step-badge">9</div>
        <h2>Output — Contextualized Embedding</h2>
      </div>
      <div class="card-body">
        <p style="color:var(--text-dim);font-size:0.9rem;margin-bottom:1rem;">
          Finally: weighted sum of all Value vectors using attention weights. <span id="out-focused" style="color:var(--teal);font-family:'JetBrains Mono',monospace;"></span> is now enriched with context.
        </p>
        <div id="output-display" style="font-family:'JetBrains Mono',monospace;font-size:0.85rem;background:rgba(0,0,0,0.25);border-radius:12px;padding:1rem;border:1px solid var(--border);"></div>
        <div class="formula-box" style="margin-top:1rem;">
          <div class="formula">output = Σ (attention_weight × V)</div>
          <div class="formula-label">Each token's output = weighted blend of all Value vectors</div>
        </div>
      </div>
    </div>

    <!-- STEP 10: Interactive Simulator -->
    <div class="section-card pulse">
      <div class="card-header">
        <div class="step-badge" style="background:linear-gradient(135deg,#a78bfa,#7c3aed);">10</div>
        <h2>Full Pipeline Simulator — Animated Step by Step</h2>
        <div style="margin-left:auto;display:flex;gap:0.75rem;align-items:center;">
          <div class="toggle-wrap">
            <label class="toggle"><input type="checkbox" id="explain-toggle" checked><span class="toggle-slider"></span></label>
            <span>Explain</span>
          </div>
        </div>
      </div>
      <div class="card-body">
        <!-- Controls -->
        <div class="sim-controls" style="margin-bottom:1.2rem;">
          <button class="ctrl-btn" id="sim-prev" title="Previous"><i class="fas fa-step-backward"></i></button>
          <button class="ctrl-btn primary" id="sim-play" title="Play/Pause"><i class="fas fa-pause" id="play-icon"></i></button>
          <button class="ctrl-btn" id="sim-next" title="Next"><i class="fas fa-step-forward"></i></button>
          <div class="stage-dots" id="stage-dots"></div>
          <div class="focus-chip" id="sim-focus-chip">Focus: Satyam</div>
          <button class="ctrl-btn" id="sim-reset" title="Reset Focus" style="margin-left:auto;font-size:0.75rem;width:auto;padding:0 0.75rem;border-radius:999px;">Reset</button>
        </div>
        <!-- Pipeline stages -->
        <div class="pipeline" id="pipeline"></div>
        <!-- Explanation -->
        <div id="sim-explain" class="explain-box" style="margin-top:1rem;"></div>
      </div>
    </div>

    <!-- STEP 11: From Attention to LLM -->
    <div class="section-card">
      <div class="card-header">
        <div class="step-badge">11</div>
        <h2>From Attention to LLM</h2>
      </div>
      <div class="card-body">
        <p style="color:var(--text-dim);font-size:0.9rem;margin-bottom:1.2rem;">
          A single attention layer is just the beginning. Real LLMs stack this into massive architectures.
        </p>
        <div class="llm-grid">
          <div class="llm-card">
            <div class="llm-card-icon">🏗️</div>
            <div class="llm-card-title">96 Layers</div>
            <div class="llm-card-desc">GPT-4 runs this attention block 96 times in sequence. Each layer refines understanding.</div>
          </div>
          <div class="llm-card">
            <div class="llm-card-icon">🧠</div>
            <div class="llm-card-title">Multi-Head</div>
            <div class="llm-card-desc">Run 8–96 separate Q,K,V sets in parallel. Each "head" looks for different patterns.</div>
          </div>
          <div class="llm-card">
            <div class="llm-card-icon">⚡</div>
            <div class="llm-card-title">Feed-Forward</div>
            <div class="llm-card-desc">After attention, a neural net processes each position independently.</div>
          </div>
          <div class="llm-card">
            <div class="llm-card-icon">🔗</div>
            <div class="llm-card-title">Residuals</div>
            <div class="llm-card-desc">E' = E + Attention(E). Skip connections prevent vanishing gradients.</div>
          </div>
        </div>
        <div class="formula-box" style="margin-top:1.2rem;">
          <div class="formula">Attention(Q, K, V) = softmax(QKᵀ / √d) × V</div>
          <div class="formula-label">The complete formula. Stack this 96× with multi-head = transformer.</div>
        </div>
      </div>
    </div>

    <!-- STEP 12: Reasoning -->
    <div class="section-card">
      <div class="card-header">
        <div class="step-badge">12</div>
        <h2>How Q&A and Reasoning Work</h2>
      </div>
      <div class="card-body">
        <p style="color:var(--text-dim);font-size:0.9rem;margin-bottom:1rem;">LLMs don't "understand" — they predict the next token based on learned patterns.</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div class="qkv-card">
            <div class="qkv-label" style="color:#f87171;">Direct Answering</div>
            <div class="qkv-role">Question → Answer<br>Hard jump. Often fails on complex tasks.</div>
          </div>
          <div class="qkv-card">
            <div class="qkv-label" style="color:#34d399;">Chain-of-Thought</div>
            <div class="qkv-role">Question → Step 1 → Step 2 → Answer<br>Each step becomes context for the next prediction. Much stronger.</div>
          </div>
        </div>
        <div class="explain-box" style="margin-top:1rem;">
          <strong>This is why prompting matters.</strong> The better you structure your prompt, the better the model can pattern-match to high-quality training sequences.
        </div>
      </div>
    </div>

  </div><!-- /container -->

  <footer>
    <div class="socials">
      <a href="https://www.instagram.com/" target="_blank"><i class="fab fa-instagram fa-lg"></i></a>
      <a href="https://www.linkedin.com/in/satyam-kumar5286o" target="_blank"><i class="fab fa-linkedin-in fa-lg"></i></a>
      <a href="https://youtube.com/@observe_with_satyam" target="_blank"><i class="fab fa-youtube fa-lg"></i></a>
      <a href="https://t.me/CA_Protracker" target="_blank"><i class="fab fa-telegram-plane fa-lg"></i></a>
    </div>
    <p>© 2026 Observe with Satyam — AI Deep Dive Series</p>
  </footer>
</div><!-- /tab-attn -->

<!-- ══════════════════════════════════════════════
     TAB 2 — PROMPT FRAMEWORKS MIND MAP
══════════════════════════════════════════════ -->
<div class="tab-content" id="tab-mindmap">
  <div class="mindmap-outer">
    <div class="mindmap-hero">
      <div class="hero-eyebrow" style="color:var(--gold);border-color:rgba(245,166,35,0.3);background:rgba(245,166,35,0.08);">
        <i class="fas fa-project-diagram"></i> Interactive Mind Map
      </div>
      <h1>9 Prompt Frameworks</h1>
      <p>Click any node to unlock the full form, real-life use cases & a ready-to-use prompt.</p>
    </div>

    <div class="mindmap-canvas-wrap">
      <div id="mmCanvas">
        <svg id="mmSvg">
          <defs>
            <linearGradient id="lineGrad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#f5a623" stop-opacity="0.8"/>
              <stop offset="100%" stop-color="#ffd166" stop-opacity="0.4"/>
            </linearGradient>
            <filter id="lineGlow">
              <feGaussianBlur stdDeviation="2" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
        </svg>
        <!-- Central hub -->
        <div class="mm-hub">
          <i class="fas fa-brain"></i>
          <div class="mm-hub-title">PROMPT<br>FRAMEWORKS</div>
          <div class="mm-hub-sub">9 pillars · click to explore</div>
        </div>
        <!-- Nodes injected by JS -->
      </div>
    </div>

    <div style="text-align:center;padding:1.5rem 0 3rem;color:#64748b;font-size:0.85rem;">
      <i class="fas fa-hand-pointer" style="color:var(--gold-dim);"></i> &nbsp;Click any node to explore the full framework with examples
    </div>
  </div>
</div>

<!-- ═══════════ MODAL ═══════════ -->
<div class="modal-bg" id="modal-bg">
  <div class="modal" id="modal">
    <div class="modal-head">
      <h2 id="modal-title">RACE</h2>
      <button class="modal-close" id="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body" id="modal-body"></div>
  </div>
</div>

<script>
// ════════════════════════════════
//  DATA
// ════════════════════════════════
const tokens = ["Satyam", "helps", "you", "upskill", "in", "AI"];
const embeddings = [
  [0.8, 0.2, 0.5, 0.9],
  [0.3, 0.7, 0.4, 0.2],
  [0.6, 0.4, 0.8, 0.3],
  [0.4, 0.9, 0.3, 0.7],
  [0.2, 0.3, 0.6, 0.4],
  [0.9, 0.5, 0.2, 0.8]
];
const W_Q = [[0.5,0.3,0.2,0.4],[0.2,0.6,0.3,0.1],[0.4,0.2,0.5,0.3],[0.3,0.4,0.2,0.6]];
const W_K = [[0.4,0.2,0.3,0.1],[0.5,0.3,0.2,0.4],[0.2,0.4,0.6,0.1],[0.3,0.2,0.4,0.5]];
const W_V = [[0.7,0.1,0.2,0.3],[0.2,0.8,0.1,0.2],[0.3,0.1,0.7,0.2],[0.1,0.2,0.3,0.6]];

function matVec(e, W) {
  let r = [0,0,0,0];
  for (let i=0;i<4;i++) for (let j=0;j<4;j++) r[i] += e[j] * W[j][i];
  return r.map(v => +v.toFixed(4));
}
const Qs = embeddings.map(e => matVec(e, W_Q));
const Ks = embeddings.map(e => matVec(e, W_K));
const Vs = embeddings.map(e => matVec(e, W_V));
const sqrtD = Math.sqrt(4);

function dot(a, b) { return a.reduce((s,v,i) => s + v*b[i], 0); }
const rawScores = tokens.map((_,i) => tokens.map((_,j) => +(dot(Qs[i], Ks[j]) / sqrtD).toFixed(4)));
function softmax(row) {
  const mx = Math.max(...row);
  const exps = row.map(v => Math.exp(v - mx));
  const sum = exps.reduce((a,b) => a+b, 0);
  return exps.map(v => +(v/sum).toFixed(4));
}
const attnW = rawScores.map(row => softmax(row));
const outputs = tokens.map((_,i) => {
  let out = [0,0,0,0];
  for (let j=0;j<tokens.length;j++) {
    const w = attnW[i][j];
    for (let d=0;d<4;d++) out[d] += w * Vs[j][d];
  }
  return out.map(v => +v.toFixed(4));
});

// ════════════════════════════════
//  STATE
// ════════════════════════════════
let selIdx = 0;    // selected token
let stage = 0;     // 0-4 for simulator
let playing = true;
let timerId = null;

// ════════════════════════════════
//  TAB SWITCHING
// ════════════════════════════════
function switchTab(t) {
  document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
  document.getElementById('tab-' + t).classList.add('active');
  document.getElementById('btn-' + t).classList.add('active');
  if (t === 'mindmap') { setTimeout(initMindMap, 50); }
}

// ════════════════════════════════
//  HELPERS
// ════════════════════════════════
function renderTokensRow() {
  const el = document.getElementById('tokens-row');
  el.innerHTML = tokens.map((t,i) => `
    <div class="token ${i===selIdx?'selected':''}" data-i="${i}">
      <span>${t}</span>
      <span class="token-idx">${i}</span>
    </div>`).join('');
  el.querySelectorAll('.token').forEach(tok => tok.addEventListener('click', () => {
    selIdx = +tok.dataset.i;
    updateAll();
  }));
}

function renderEmbedding() {
  const el = document.getElementById('embedding-display');
  const e = embeddings[selIdx];
  el.innerHTML = `<span style="color:var(--teal)">${tokens[selIdx]}</span> <span style="color:var(--text-dim)">→</span> [${e.map(v => `<span style="color:var(--gold)">${v}</span>`).join(', ')}]
<br><span style="color:var(--text-dim);font-size:0.75rem;">All ${tokens.length} token embeddings:</span>
${tokens.map((t,i) => `\n<span style="color:${i===selIdx?'var(--teal)':'var(--text-dim)'}">${t.padEnd(8)}</span> → [${embeddings[i].join(', ')}]`).join('')}`;
}

function renderQKV() {
  document.getElementById('qkv-focused').textContent = tokens[selIdx];
  const el = document.getElementById('qkv-vectors');
  const q = Qs[selIdx], k = Ks[selIdx], v = Vs[selIdx];
  el.innerHTML = `
    <div class="qkv-card">
      <div class="qkv-label q">Q — Query</div>
      <div class="qkv-role">"What is ${tokens[selIdx]} looking for?"</div>
      <div class="qkv-vec">[${q.join(', ')}]</div>
    </div>
    <div class="qkv-card">
      <div class="qkv-label k">K — Key</div>
      <div class="qkv-role">"What does ${tokens[selIdx]} offer?"</div>
      <div class="qkv-vec">[${k.join(', ')}]</div>
    </div>
    <div class="qkv-card">
      <div class="qkv-label v">V — Value</div>
      <div class="qkv-role">"Info ${tokens[selIdx]} will share"</div>
      <div class="qkv-vec">[${v.join(', ')}]</div>
    </div>`;
}

function renderScores() {
  document.getElementById('scores-focused').textContent = tokens[selIdx];
  const scores = rawScores[selIdx];
  const mx = Math.max(...scores);
  document.getElementById('scores-bars').innerHTML = tokens.map((t,i) => `
    <div class="bar-row">
      <div class="bar-label">${t}</div>
      <div class="bar-track"><div class="bar-fill" style="width:${Math.max(0,(scores[i]/mx)*100).toFixed(1)}%"></div></div>
      <div class="bar-val">${scores[i]}</div>
    </div>`).join('');
}

function renderSoftmax() {
  document.getElementById('sm-focused').textContent = tokens[selIdx];
  const probs = attnW[selIdx];
  document.getElementById('softmax-bars').innerHTML = tokens.map((t,i) => `
    <div class="bar-row">
      <div class="bar-label">${t}</div>
      <div class="bar-track"><div class="bar-fill gold" style="width:${(probs[i]*100).toFixed(1)}%"></div></div>
      <div class="bar-val">${(probs[i]*100).toFixed(0)}%</div>
    </div>`).join('');
}

function renderFlow() {
  document.getElementById('flow-focused').textContent = tokens[selIdx];
  const row = document.getElementById('flow-tokens-row');
  row.innerHTML = tokens.map((t,i) => `
    <div class="flow-token">
      <div class="flow-token-box ${i===selIdx?'source':''}">${t}</div>
      <div class="flow-attn-label">${(attnW[selIdx][i]*100).toFixed(0)}%</div>
    </div>`).join('');

  requestAnimationFrame(() => {
    const svg = document.getElementById('flow-svg');
    const boxes = row.querySelectorAll('.flow-token-box');
    const visBounds = document.getElementById('flow-vis').getBoundingClientRect();
    const srcBox = boxes[selIdx].getBoundingClientRect();
    const srcX = srcBox.left + srcBox.width/2 - visBounds.left;
    const srcY = srcBox.top + srcBox.height/2 - visBounds.top;

    let lines = '';
    boxes.forEach((box, i) => {
      if (i === selIdx) return;
      const bRect = box.getBoundingClientRect();
      const tx = bRect.left + bRect.width/2 - visBounds.left;
      const ty = bRect.top + bRect.height/2 - visBounds.top;
      const w = attnW[selIdx][i];
      const sw = 1 + w * 14;
      const alpha = 0.15 + w * 0.85;
      lines += `<line x1="${srcX}" y1="${srcY}" x2="${tx}" y2="${ty}" stroke="rgba(0,212,200,${alpha})" stroke-width="${sw}" stroke-linecap="round" class="animated-dash" stroke-dasharray="8 5"/>`;
    });
    svg.innerHTML = `<svg width="100%" height="100%">${lines}</svg>`;
  });
}

function renderHeatmap() {
  const n = tokens.length;
  const el = document.getElementById('heatmap');
  el.style.gridTemplateColumns = `80px repeat(${n}, 1fr)`;
  let html = `<div></div>`;
  tokens.forEach(t => html += `<div class="hm-header">${t}</div>`);
  tokens.forEach((t,i) => {
    html += `<div class="hm-row-label">${t}</div>`;
    tokens.forEach((_,j) => {
      const v = attnW[i][j];
      const alpha = 0.1 + v * 0.85;
      const bg = `rgba(0,212,200,${alpha})`;
      const textColor = v > 0.5 ? '#0f172a' : 'var(--text)';
      html += `<div class="hm-cell" data-row="${i}" data-col="${j}" style="background:${bg};color:${textColor};">${(v*100).toFixed(0)}%</div>`;
    });
  });
  el.innerHTML = html;
  el.querySelectorAll('.hm-cell').forEach(cell => {
    cell.addEventListener('mouseenter', () => {
      const r = +cell.dataset.row, c = +cell.dataset.col;
      el.querySelectorAll('.hm-cell').forEach(cc => {
        if (+cc.dataset.row===r || +cc.dataset.col===c) cc.classList.add('row-highlight');
      });
    });
    cell.addEventListener('mouseleave', () => el.querySelectorAll('.hm-cell').forEach(cc => cc.classList.remove('row-highlight')));
    cell.addEventListener('click', () => { selIdx = +cell.dataset.row; updateAll(); });
  });
}

function renderOutput() {
  document.getElementById('out-focused').textContent = tokens[selIdx];
  const probs = attnW[selIdx];
  const topJ = probs.indexOf(Math.max(...probs));
  const outVec = outputs[selIdx];
  document.getElementById('output-display').innerHTML = `<span style="color:var(--text-dim)">output</span>(<span style="color:var(--teal)">${tokens[selIdx]}</span>) = [${outVec.map(v => `<span style="color:var(--gold)">${v}</span>`).join(', ')}]
<br><span style="color:var(--text-dim);font-size:0.75rem;">→ Paid most attention to <span style="color:var(--teal)">${tokens[topJ]}</span> (${(probs[topJ]*100).toFixed(0)}%)</span>`;
}

// ════════════════════════════════
//  SIMULATOR
// ════════════════════════════════
const stageData = [
  {
    label: '① Input Tokens',
    content: () => tokens.map((t,i) => `<span style="color:${i===selIdx?'var(--teal)':'var(--text-dim)'}">${t}</span>`).join(' · '),
    explain: () => `<strong>Stage 1: Input Tokens.</strong> We start with the raw sentence. Currently focusing on <strong style="color:var(--teal)">${tokens[selIdx]}</strong>. Our goal is to enrich its embedding with context from surrounding words.`
  },
  {
    label: '② Q, K, V',
    content: () => `Q: [${Qs[selIdx].join(', ')}]<br>K: [${Ks[selIdx].join(', ')}]<br>V: [${Vs[selIdx].join(', ')}]`,
    explain: () => `<strong>Stage 2: Q, K, V Projection.</strong> <strong style="color:var(--teal)">${tokens[selIdx]}</strong> is transformed into three vectors. Q asks "what am I looking for?", K says "what do I offer?", V holds the actual content to share.`
  },
  {
    label: '③ Scores',
    content: () => {
      const sc = rawScores[selIdx];
      return tokens.map((t,i) => `${t}: <strong>${sc[i]}</strong>`).join('<br>');
    },
    explain: () => `<strong>Stage 3: Dot Product Scores.</strong> We compute Q·K/√d for each token pair. Higher score = stronger relevance. <strong style="color:var(--teal)">${tokens[selIdx]}</strong>'s Query is being compared to every token's Key.`
  },
  {
    label: '④ Softmax %',
    content: () => {
      const probs = attnW[selIdx];
      const top = probs.indexOf(Math.max(...probs));
      return tokens.map((t,i) => `${t}: <strong style="color:${i===top?'var(--gold)':'inherit'}">${(probs[i]*100).toFixed(0)}%</strong>`).join('<br>');
    },
    explain: () => {
      const probs = attnW[selIdx];
      const top = probs.indexOf(Math.max(...probs));
      return `<strong>Stage 4: Softmax Normalization.</strong> Raw scores become probabilities. <strong style="color:var(--teal)">${tokens[selIdx]}</strong> pays most attention to <strong style="color:var(--gold)">${tokens[top]}</strong> (${(probs[top]*100).toFixed(0)}%). All weights sum to 100%.`;
    }
  },
  {
    label: '⑤ Output',
    content: () => `[${outputs[selIdx].join(', ')}]<br><span style="font-size:0.7rem;color:var(--teal)">contextualized</span>`,
    explain: () => `<strong>Stage 5: Weighted Sum → Output.</strong> Each Value vector is weighted by its attention probability and summed. The result is a new, context-enriched embedding for <strong style="color:var(--teal)">${tokens[selIdx]}</strong>. It now "knows" about the whole sentence.`
  }
];

function buildPipeline() {
  const el = document.getElementById('pipeline');
  el.innerHTML = stageData.map((s,i) => `
    <div class="pipe-stage ${i===stage?'active':''}" id="pipe-${i}" data-stage="${i}">
      <div class="pipe-stage-num">${s.label.split(' ')[0]}</div>
      <div class="pipe-stage-title">${s.label.slice(2).trim()}</div>
      <div class="pipe-stage-content" id="pipe-content-${i}"></div>
    </div>`).join('');
  stageData.forEach((s,i) => {
    document.getElementById(`pipe-content-${i}`).innerHTML = s.content();
    document.getElementById(`pipe-${i}`).addEventListener('click', () => { stage = i; updateSimulator(); });
  });
  const dots = document.getElementById('stage-dots');
  dots.innerHTML = stageData.map((_,i) => `<div class="stage-dot ${i===stage?'active':''}" data-stage="${i}"></div>`).join('');
  dots.querySelectorAll('.stage-dot').forEach(d => d.addEventListener('click', () => { stage = +d.dataset.stage; updateSimulator(); }));
}

function updateSimulator() {
  document.querySelectorAll('.pipe-stage').forEach((el,i) => el.classList.toggle('active', i===stage));
  document.querySelectorAll('.stage-dot').forEach((el,i) => el.classList.toggle('active', i===stage));
  stageData.forEach((s,i) => { const el = document.getElementById(`pipe-content-${i}`); if(el) el.innerHTML = s.content(); });
  const expOn = document.getElementById('explain-toggle').checked;
  document.getElementById('sim-explain').innerHTML = expOn ? stageData[stage].explain() : '<span style="color:var(--text-dim)">Toggle Explain ON to see step explanation.</span>';
  document.getElementById('sim-focus-chip').textContent = `Focus: ${tokens[selIdx]}`;
}

function startAuto() {
  if (timerId) return;
  timerId = setInterval(() => {
    stage = (stage + 1) % stageData.length;
    updateSimulator();
  }, 3500);
}
function stopAuto() { clearInterval(timerId); timerId = null; }

function updateAll() {
  renderTokensRow();
  renderEmbedding();
  renderQKV();
  renderScores();
  renderSoftmax();
  renderFlow();
  renderHeatmap();
  renderOutput();
  buildPipeline();
  updateSimulator();
}

// Sim controls
document.getElementById('sim-play').addEventListener('click', () => {
  playing = !playing;
  document.getElementById('play-icon').className = playing ? 'fas fa-pause' : 'fas fa-play';
  playing ? startAuto() : stopAuto();
});
document.getElementById('sim-prev').addEventListener('click', () => { stopAuto(); playing=false; document.getElementById('play-icon').className='fas fa-play'; stage=(stage-1+stageData.length)%stageData.length; updateSimulator(); });
document.getElementById('sim-next').addEventListener('click', () => { stopAuto(); playing=false; document.getElementById('play-icon').className='fas fa-play'; stage=(stage+1)%stageData.length; updateSimulator(); });
document.getElementById('sim-reset').addEventListener('click', () => { selIdx=0; updateAll(); });
document.getElementById('explain-toggle').addEventListener('change', updateSimulator);

// ════════════════════════════════
//  MIND MAP
// ════════════════════════════════
const frameworks = [
  {
    name: "RACE",
    fullForm: "Role · Action · Context · Expectation",
    letters: [["R","Role"],["A","Action"],["C","Context"],["E","Expectation"]],
    meaning: "Tell AI who it is, what to do, and exactly how you want the output formatted.",
    useCases: "WhatsApp messages to boss, leave emails, Instagram captions, summarizing notes, explaining topics simply.",
    prompt: `"Act as a career mentor (Role). Help me draft a leave message to my manager (Action). I need leave for a family function (Context). Keep it polite and under 50 words (Expectation)."`
  },
  {
    name: "CLEAR",
    fullForm: "Context · Learn · Evaluate · Action · Review",
    letters: [["C","Context"],["L","Learn"],["E","Evaluate"],["A","Action"],["R","Review"]],
    meaning: "Structure learning sessions — understand, test yourself, then improve on gaps.",
    useCases: "Exam prep, revising difficult topics, practising MCQs, interview prep, improving weak subjects.",
    prompt: `"I'm preparing for my CA exams (Context). Teach me 'Inflation' in simple terms (Learn). Give 5 MCQs to test me (Evaluate). Provide revision notes (Action). Tell me common mistakes students make (Review)."`
  },
  {
    name: "5W1H",
    fullForm: "What · Why · Who · When · Where · How",
    letters: [["W","What"],["W","Why"],["W","Who"],["W","When"],["W","Where"],["H","How"]],
    meaning: "Break any confusing topic or decision into six clear questions that cover every angle.",
    useCases: "Career choices, trip planning, understanding news, starting a side hustle, decision making.",
    prompt: `"I want to start freelancing. Explain: What options exist, Why they work in India, Who should do it, When to start, Where to find clients, How to begin step by step."`
  },
  {
    name: "PASTOR",
    fullForm: "Problem · Amplify · Story · Transformation · Offer · Response",
    letters: [["P","Problem"],["A","Amplify"],["S","Story"],["T","Transformation"],["O","Offer"],["R","Response"]],
    meaning: "Make audiences feel the pain, see the hope, and then take action — the core of all viral storytelling.",
    useCases: "LinkedIn posts, Reel scripts, client proposals, Instagram captions, convincing someone.",
    prompt: `"Write a LinkedIn post: Problem – people waste 3 hours on phone daily. Amplify – they lose years of growth. Story – a student changed and got placed at ₹18 LPA. Transformation – 3 habits that changed everything. Offer – free checklist in comments. Response – ask readers: which habit will you try?"`
  },
  {
    name: "STAR",
    fullForm: "Situation · Task · Action · Result",
    letters: [["S","Situation"],["T","Task"],["A","Action"],["R","Result"]],
    meaning: "Answer any interview question with a real story that proves your ability — not just claims.",
    useCases: "HR interview answers, college vivas, group discussions, explaining achievements in your resume.",
    prompt: `"Answer 'Tell me about a challenge you faced' using STAR. Scenario: a student leading a college fest team that had a major conflict 3 days before the event."`
  },
  {
    name: "FAB",
    fullForm: "Feature · Advantage · Benefit",
    letters: [["F","Feature"],["A","Advantage"],["B","Benefit"]],
    meaning: "Move beyond describing what something is — explain why it matters to the specific person.",
    useCases: "Pitching yourself, selling a product, convincing a friend, explaining the value of a skill.",
    prompt: `"Explain why learning communication skills is important for a fresher engineering student, using FAB framework in simple, relatable language."`
  },
  {
    name: "RISE",
    fullForm: "Role · Identify · Steps · Expectation",
    letters: [["R","Role"],["I","Identify"],["S","Steps"],["E","Expectation"]],
    meaning: "Take average AI output and turn it into something genuinely good by giving it an editor's lens.",
    useCases: "Fixing boring captions, improving email drafts, upgrading assignments, rewriting weak content.",
    prompt: `"Act as a professional editor (Role). Identify what's weak or boring in this paragraph (Identify). Suggest 3 specific improvements (Steps). Rewrite it in a confident, engaging tone for LinkedIn (Expectation)."`
  },
  {
    name: "GROW",
    fullForm: "Goal · Reality · Options · Will",
    letters: [["G","Goal"],["R","Reality"],["O","Options"],["W","Will"]],
    meaning: "Turn fuzzy goals into a clear, honest action plan — includes what's blocking you right now.",
    useCases: "Building habits, monthly planning, career direction, improving productivity, coaching sessions.",
    prompt: `"My goal is to wake up at 5 AM consistently (Goal). Currently I sleep at 1 AM and feel tired every morning (Reality). Suggest 4 realistic options to shift my routine (Options). Create a 14-day step-by-step action plan I'll actually follow (Will)."`
  },
  {
    name: "SOAP",
    fullForm: "Subject · Objective · Action · Plan",
    letters: [["S","Subject"],["O","Objective"],["A","Action"],["P","Plan"]],
    meaning: "Write professional emails and updates that are crystal-clear about what's happening and what's next.",
    useCases: "Leave emails, client progress updates, delay notifications, formal communication at work or college.",
    prompt: `"Write a professional email using SOAP about a delay in my project delivery. Subject: project delay notice. Objective: inform the client. Action: apologise and explain. Plan: share revised timeline and next steps."`
  }
];

let mmInitDone = false;
function initMindMap() {
  if (mmInitDone) return;
  mmInitDone = true;
  const canvas = document.getElementById('mmCanvas');
  // remove any old nodes
  canvas.querySelectorAll('.mm-node').forEach(el => el.remove());

  const nodes = frameworks.map((fw, idx) => {
    const node = document.createElement('div');
    node.className = 'mm-node';
    node.dataset.idx = idx;
    node.innerHTML = `
      <div class="mm-node-name">${fw.name}</div>
      <div class="mm-node-form">${fw.fullForm}</div>
      <div class="mm-node-cta"><i class="fas fa-info-circle"></i> click for insights</div>`;
    node.addEventListener('click', () => openModal(idx));
    canvas.appendChild(node);
    return node;
  });

  function layout() {
    const cW = canvas.offsetWidth;
    const cH = Math.max(canvas.offsetHeight, 650);
    const cx = cW / 2, cy = cH / 2;
    const radius = Math.min(cW * 0.34, cH * 0.34, 290);
    const step = (Math.PI * 2) / nodes.length;

    nodes.forEach((node, i) => {
      const angle = i * step - Math.PI / 2;
      const nw = node.offsetWidth || 195;
      const nh = node.offsetHeight || 110;
      const x = cx + radius * Math.cos(angle) - nw / 2;
      const y = cy + radius * Math.sin(angle) - nh / 2;
      node.style.left = x + 'px';
      node.style.top = y + 'px';
    });

    drawLines(cx, cy, nodes, canvas);
  }

  setTimeout(layout, 60);
  window.addEventListener('resize', () => { mmInitDone = false; layout(); });

  if (window.ResizeObserver) {
    new ResizeObserver(layout).observe(canvas);
  }
}

function drawLines(cx, cy, nodes, canvas) {
  const svg = document.getElementById('mmSvg');
  const cRect = canvas.getBoundingClientRect();
  svg.setAttribute('width', cRect.width);
  svg.setAttribute('height', cRect.height);

  // clear old paths
  svg.querySelectorAll('path.mm-line').forEach(el => el.remove());

  nodes.forEach(node => {
    const nRect = node.getBoundingClientRect();
    const nx = nRect.left + nRect.width/2 - cRect.left;
    const ny = nRect.top + nRect.height/2 - cRect.top;
    const dx = nx - cx, dy = ny - cy;
    const dist = Math.sqrt(dx*dx + dy*dy);
    const hubR = 100;
    const nodeR = Math.min(nRect.width, nRect.height) / 2;
    const sx = cx + dx / dist * hubR;
    const sy = cy + dy / dist * hubR;
    const ex = cx + dx / dist * (dist - nodeR * 0.7);
    const ey = cy + dy / dist * (dist - nodeR * 0.7);
    const midX = (sx + ex) / 2, midY = (sy + ey) / 2 - 18;

    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path.setAttribute('class', 'mm-line');
    path.setAttribute('d', `M${sx},${sy} Q${midX},${midY} ${ex},${ey}`);
    path.setAttribute('stroke', 'url(#lineGrad)');
    path.setAttribute('stroke-width', '2.5');
    path.setAttribute('fill', 'none');
    path.setAttribute('stroke-dasharray', '7 4');
    path.setAttribute('opacity', '0.7');
    path.setAttribute('filter', 'url(#lineGlow)');
    svg.appendChild(path);
  });
}

function openModal(idx) {
  const fw = frameworks[idx];
  document.getElementById('modal-title').textContent = fw.name + ' Framework';
  document.getElementById('modal-body').innerHTML = `
    <div class="modal-section">
      <div class="modal-section-label"><i class="fas fa-expand-alt"></i> Full Form</div>
      <p>${fw.fullForm}</p>
      <div class="modal-letters">${fw.letters.map(([l,w]) => `<div class="modal-letter-chip"><strong>${l}</strong><span>${w}</span></div>`).join('')}</div>
    </div>
    <div class="modal-section">
      <div class="modal-section-label"><i class="fas fa-seedling"></i> Simple Meaning</div>
      <p>${fw.meaning}</p>
    </div>
    <div class="modal-section">
      <div class="modal-section-label"><i class="fas fa-users"></i> Real-Life Use Cases</div>
      <p>${fw.useCases}</p>
    </div>
    <div class="modal-section">
      <div class="modal-section-label"><i class="fas fa-comment-dots"></i> Ready-to-Use Prompt</div>
      <div class="modal-prompt-box">${fw.prompt}</div>
    </div>`;
  document.getElementById('modal-bg').classList.add('open');
}

document.getElementById('modal-close').addEventListener('click', () => document.getElementById('modal-bg').classList.remove('open'));
document.getElementById('modal-bg').addEventListener('click', e => { if (e.target === document.getElementById('modal-bg')) document.getElementById('modal-bg').classList.remove('open'); });

// ════════════════════════════════
//  INIT
// ════════════════════════════════
updateAll();
startAuto();
</script>
</body>
</html>
